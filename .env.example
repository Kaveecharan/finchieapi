# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── CORS & Cookie ─────────────────────────────────────────────────────────────
# Comma-separated for multiple origins: http://localhost:8081,https://app.example.com
CORS_ORIGIN=http://localhost:8081
COOKIE_DOMAIN=
TRUSTED_PROXIES=1

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:pass@cluster/db?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (min 32 chars — use: openssl rand -hex 32) ───────────────────
JWT_ACCESS_SECRET=replace_with_32plus_char_random_string_here_abc123
JWT_REFRESH_SECRET=replace_with_different_32plus_char_random_string_xyz789
ACCESS_TOKEN_TTL=30m
REFRESH_TOKEN_TTL_DAYS=7

# ── Password Pepper (min 32 chars — store in secrets manager, NOT in git) ────
BCRYPT_PEPPER=replace_with_32plus_char_random_pepper_string_do_not_commit

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM_NAME=Kodeum
SUPPORT_EMAIL=

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Kodeum
MFA_ISSUER=Kodeum

# ── OpenAI (optional — AI insights disabled when absent) ──────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Cloudflare Turnstile (optional — skipped in dev when blank) ───────────────
TURNSTILE_SECRET_KEY=

# ── Stripe (optional — subscription features disabled when absent) ────────────
# Get keys from: https://dashboard.stripe.com/test/apikeys
# Run: stripe listen --forward-to localhost:3000/subscriptions/webhook
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Currency ──────────────────────────────────────────────────────────────────
CURRENCY_SYMBOL=Rs
